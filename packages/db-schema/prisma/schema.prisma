generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum CrawlSource {
  WIKIDATA
  NAMUWIKI
  ASTRODATABANK
  USER_SUBMIT
}

enum CrawlRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

enum RawProcessStatus {
  PENDING
  PROCESSING
  PROCESSED
  PROCESSED_WITHOUT_BIRTH_DATE
  FAILED_RETRYABLE
  FAILED_PERMANENT
}

enum BirthDatePrecision {
  UNKNOWN
  YEAR
  MONTH
  DAY
}

enum BirthCalendarStatus {
  UNKNOWN
  SOLAR_ASSUMED
  SOLAR_CONFIRMED
  LUNAR_CONFIRMED
}

enum WikidataSeedStatus {
  PENDING
  FETCHING
  FETCHED
  FAILED
  SKIPPED
}



model RawWikipedia {
  id            Int              @id @default(autoincrement())
  wikidataId    String           @unique @map("wikidata_id") @db.VarChar(32)
  title         String           @db.VarChar(255)
  language      String           @default("ko") @db.VarChar(8)
  sourceUrl     String           @map("source_url") @db.VarChar(512)
  rawJson       Json             @map("raw_json")
  rawHash       String?          @map("raw_hash") @db.Char(64)
  rawRevisionId String?          @map("raw_revision_id") @db.VarChar(64)
  processStatus RawProcessStatus @default(PENDING) @map("process_status")
  processError  String?          @map("process_error") @db.Text
  attemptCount  Int              @default(0) @map("attempt_count")
  scrapedAt     DateTime         @default(now()) @map("scraped_at")
  lastAttemptAt DateTime?        @map("last_attempt_at")
  processedAt   DateTime?        @map("processed_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  curatedPerson      CuratedPerson?
  wikidataPeopleSeed WikidataPeopleSeed?

  @@index([processStatus, scrapedAt])
  @@index([rawHash])
  @@map("raw_wikipedia")
}

model RawAstroDatabank {
  id            Int              @id @default(autoincrement())
  url           String           @unique @db.VarChar(512)
  title         String           @db.VarChar(255)
  rawHtml       String           @map("raw_html") @db.LongText
  processStatus RawProcessStatus @default(PENDING) @map("process_status")
  processError  String?          @map("process_error") @db.Text
  attemptCount  Int              @default(0) @map("attempt_count")
  scrapedAt     DateTime         @default(now()) @map("scraped_at")
  lastAttemptAt DateTime?        @map("last_attempt_at")
  processedAt   DateTime?        @map("processed_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  curatedPerson CuratedPerson?

  @@index([processStatus, scrapedAt])
  @@map("raw_astrodatabank")
}

model WikidataPeopleSeed {
  id             Int                @id @default(autoincrement())
  wikidataId     String             @unique @map("wikidata_id") @db.VarChar(32)
  label          String?            @db.VarChar(191)
  description    String?            @db.VarChar(512)
  birthDate      String?            @map("birth_date") @db.VarChar(32)
  sourceQuery    String             @default("human_with_birth_date") @map("source_query") @db.VarChar(64)
  status         WikidataSeedStatus @default(PENDING)
  rawWikipediaId Int?               @unique @map("raw_wikipedia_id")
  attemptCount   Int                @default(0) @map("attempt_count")
  errorMessage   String?            @map("error_message") @db.Text
  discoveredAt   DateTime           @default(now()) @map("discovered_at")
  lastAttemptAt  DateTime?          @map("last_attempt_at")
  fetchedAt      DateTime?          @map("fetched_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  rawWikipedia RawWikipedia? @relation(fields: [rawWikipediaId], references: [id], onDelete: SetNull)

  @@index([status, discoveredAt])
  @@index([lastAttemptAt])
  @@map("wikidata_people_seeds")
}

model CuratedPerson {
  id                     Int                 @id @default(autoincrement())
  displayName            String              @map("display_name") @db.VarChar(191)
  originalName           String?             @map("original_name") @db.VarChar(191)
  sortName               String?             @map("sort_name") @db.VarChar(191)
  birthYear              Int?                @map("birth_year") @db.SmallInt
  birthMonth             Int?                @map("birth_month") @db.TinyInt
  birthDay               Int?                @map("birth_day") @db.TinyInt
  birthTime              String?             @map("birth_time") @db.VarChar(16)
  gender                 String?             @map("gender") @db.VarChar(16)
  roddenRating           String?             @map("rodden_rating") @db.VarChar(16)
  birthPrecision         BirthDatePrecision  @default(UNKNOWN) @map("birth_precision")
  birthCalendarStatus    BirthCalendarStatus @default(UNKNOWN) @map("birth_calendar_status")
  deathYear              Int?                @map("death_year") @db.SmallInt
  deathMonth             Int?                @map("death_month") @db.TinyInt
  deathDay               Int?                @map("death_day") @db.TinyInt
  citizenshipCountryName String?             @map("citizenship_country_name") @db.VarChar(128)
  birthPlaceName         String?             @map("birth_place_name") @db.VarChar(191)
  birthCountryName       String?             @map("birth_country_name") @db.VarChar(128)
  occupationName         String?             @map("occupation_name") @db.VarChar(128)
  source                 CrawlSource
  sourceId               String              @map("source_id") @db.VarChar(512)
  sourceUrl              String              @map("source_url") @db.VarChar(512)
  wikipediaUrl           String?             @map("wikipedia_url") @db.VarChar(512)
  imageUrl               String?             @map("image_url") @db.VarChar(512)
  rawWikipediaId         Int?                @unique @map("raw_wikipedia_id")
  rawAstrodatabankId     Int?                @unique @map("raw_astrodatabank_id")
  bonwonSajuId           Int?                @map("bonwon_saju_id")
  charyeokSajuId         Int?                @map("charyeok_saju_id")
  buheojaBonwonSajuId    Int?                @map("buheoja_bonwon_saju_id")
  buheojaCharyeokSajuId  Int?                @map("buheoja_charyeok_saju_id")
  heojaBonwonSajuId      Int?                @map("heoja_bonwon_saju_id")
  heojaCharyeokSajuId    Int?                @map("heoja_charyeok_saju_id")
  sajuComputedAt         DateTime?           @map("saju_computed_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  rawWikipedia       RawWikipedia?      @relation(fields: [rawWikipediaId], references: [id])
  rawAstrodatabank   RawAstroDatabank?  @relation(fields: [rawAstrodatabankId], references: [id])
  
  bonwonSaju             MasterSaju?    @relation("BonwonSaju", fields: [bonwonSajuId], references: [id])
  charyeokSaju           MasterSaju?    @relation("CharyeokSaju", fields: [charyeokSajuId], references: [id])
  buheojaBonwonSaju      MasterSaju?    @relation("BuheojaBonwonSaju", fields: [buheojaBonwonSajuId], references: [id])
  buheojaCharyeokSaju    MasterSaju?    @relation("BuheojaCharyeokSaju", fields: [buheojaCharyeokSajuId], references: [id])
  heojaBonwonSaju        MasterSaju?    @relation("HeojaBonwonSaju", fields: [heojaBonwonSajuId], references: [id])
  heojaCharyeokSaju      MasterSaju?    @relation("HeojaCharyeokSaju", fields: [heojaCharyeokSajuId], references: [id])

  @@unique([source, sourceId])
  @@index([displayName])
  @@index([birthYear, birthMonth, birthDay])
  @@index([citizenshipCountryName])
  @@index([birthCountryName])
  @@map("curated_people")
}

model CrawlerRun {
  id             Int            @id @default(autoincrement())
  source         CrawlSource
  command        String         @db.VarChar(64)
  status         CrawlRunStatus @default(RUNNING)
  requestedCount Int            @default(0) @map("requested_count")
  succeededCount Int            @default(0) @map("succeeded_count")
  failedCount    Int            @default(0) @map("failed_count")
  skippedCount   Int            @default(0) @map("skipped_count")
  message        String?        @db.Text
  startedAt      DateTime       @default(now()) @map("started_at")
  finishedAt     DateTime?      @map("finished_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([source, status, startedAt])
  @@map("crawler_runs")
}

model MasterSaju {
  id              Int      @id @default(autoincrement())
  
  yearStem    String   @map("year_stem") @db.VarChar(4)
  yearBranch  String   @map("year_branch") @db.VarChar(4)
  monthStem   String   @map("month_stem") @db.VarChar(4)
  monthBranch String   @map("month_branch") @db.VarChar(4)
  dayStem     String   @map("day_stem") @db.VarChar(4)
  dayBranch   String   @map("day_branch") @db.VarChar(4)

  curatedPeopleBonwon          CuratedPerson[] @relation("BonwonSaju")
  curatedPeopleCharyeok        CuratedPerson[] @relation("CharyeokSaju")
  curatedPeopleBuheojaBonwon   CuratedPerson[] @relation("BuheojaBonwonSaju")
  curatedPeopleBuheojaCharyeok CuratedPerson[] @relation("BuheojaCharyeokSaju")
  curatedPeopleHeojaBonwon     CuratedPerson[] @relation("HeojaBonwonSaju")
  curatedPeopleHeojaCharyeok   CuratedPerson[] @relation("HeojaCharyeokSaju")

  @@unique([yearStem, yearBranch, monthStem, monthBranch, dayStem, dayBranch], name: "saju_idx")
  @@index([dayStem, dayBranch])
  @@index([monthStem, monthBranch])
  @@index([yearStem, yearBranch])
  @@map("master_saju")
}
